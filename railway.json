{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm install && vite build"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "NODE_ENV=production node --loader tsx/esm server/_core/index.ts",
    "restartPolicyMaxRetries": 5
  }
}
